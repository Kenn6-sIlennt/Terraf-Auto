# ─────────────────────────────────────────
# Terraform
# ─────────────────────────────────────────
# State files (mengandung sensitif data & resource tracking)
*.tfstate
*.tfstate.*
terraform.tfstate.backup
.terraform/
.terraform.lock.hcl

# Variable files dengan nilai sensitif
terraform.tfvars
*.auto.tfvars
*.auto.tfvars.json

# Crash log files
crash.log
crash.*.log

# ─────────────────────────────────────────
# Bash / Script
# ─────────────────────────────────────────
# Backup files
*.bak
*.swp
*~

# Log files dari script
*.log
logs/

# ─────────────────────────────────────────
# OS / Editor
# ─────────────────────────────────────────
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.fuse_hidden*
.Trash-*
.nfs*

# IDE / Editor
.idea/
.vscode/
*.sublime-project
*.sublime-workspace
.project
.settings/

# ─────────────────────────────────────────
# Security / Secrets
# ─────────────────────────────────────────
# SSH keys (private)
*.pem
*.key
id_rsa
id_ed25519
*.ppk

# Environment files dengan secrets
.env
.env.local
.env.*.local

# Cloud credentials
*.credentials
aws_credentials
gcp_key.json

# ─────────────────────────────────────────
# Cloud-Init / ISO (jika ada file besar)
# ─────────────────────────────────────────
*.iso
*.img
*.qcow2
*.raw
cloud-init/*.iso

# ─────────────────────────────────────────
# Documentation (opsional)
# ─────────────────────────────────────────
# Build output
dist/
build/

# Node modules (jika ada frontend tooling)
node_modules/
npm-debug.log*
yarn-debug.log*
